# ═══════════════════════════════════════════════════════════════════════════
# SZPERACZ OLX — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUKCJE:
# 1. Skopiuj ten plik jako .env:
#    cp .env.example .env
#
# 2. Wypełnij wartości poniżej
#
# 3. NIE commituj pliku .env do repozytorium!
#
# ═══════════════════════════════════════════════════════════════════════════

# ─── Email Configuration ───────────────────────────────────────────────────

# Gmail App Password (16 znaków, bez spacji)
# Wygeneruj tutaj: https://myaccount.google.com/apppasswords
#
# WAŻNE: To NIE jest Twoje hasło do Gmail!
# Musisz włączyć weryfikację dwuetapową i wygenerować App Password.
#
# Przykład: abcd efgh ijkl mnop (wklej bez spacji: abcdefghijklmnop)
EMAIL_PASSWORD=

# Adres email nadawcy (konto Gmail z włączonym App Password)
SENDER_EMAIL=

# Adres email odbiorcy raportu tygodniowego
RECEIVER_EMAIL=

# ─── GitHub Configuration (opcjonalne - tylko dla lokalnego testowania) ────

# Personal Access Token do uruchamiania GitHub Actions lokalnie
# Scope: repo lub workflow
# Generuj tutaj: https://github.com/settings/tokens/new
#
# UWAGA: Ten token NIE jest potrzebny w produkcji (GitHub Actions)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Logging Configuration (opcjonalne) ────────────────────────────────────

# Poziom logowania (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Katalog na logi (domyślnie: ./logs/)
# LOG_DIR=./logs/

# ─── Advanced Configuration (opcjonalne) ───────────────────────────────────

# User-Agent rotation (czy używać rotacji User-Agent)
# USE_USER_AGENT_ROTATION=true

# Request timeout (sekundy)
# REQUEST_TIMEOUT=30

# Max retry attempts dla failed requests
# MAX_RETRY_ATTEMPTS=3

# Delay between retries (sekundy)
# RETRY_DELAY=5

# ═══════════════════════════════════════════════════════════════════════════
# PRZYKŁADOWA KONFIGURACJA (DEVELOPMENT)
# ═══════════════════════════════════════════════════════════════════════════
#
# EMAIL_PASSWORD=abcdefghijklmnop
# LOG_LEVEL=DEBUG
# REQUEST_TIMEOUT=60
#
# ═══════════════════════════════════════════════════════════════════════════
