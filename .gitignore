# ─── IMPORTANT: Keep data/ in repo ──────────────────────────────────────────
# We want to track data/dashboard_data.json and data/szperacz_olx.xlsx
# but exclude any temporary or backup files

data/*.tmp
data/*.bak
data/*~
data/.~*

# Exclude local test data
data/test_*
data/local_*

